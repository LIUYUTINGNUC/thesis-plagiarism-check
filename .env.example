# ======================================================================
# 语义级论文查重系统 — 环境变量配置
# ======================================================================
# LLM 厂商配置
# ======================================================================

# 选择 LLM 厂商（必填）
# 可选: claude / openai / deepseek / qwen / glm / moonshot / baichuan / yi / ernie / siliconflow / spark
LLM_PROVIDER=claude

# ======================================================================
# API 密钥（根据所选厂商填写对应的密钥）
# ======================================================================

# Claude API (Anthropic)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxx

# OpenAI API
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# 国产模型 API 密钥（按需配置）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx
QWEN_API_KEY=sk-xxxxxxxxxxxx       # 阿里通义千问
GLM_API_KEY=xxxxxxxxxxxx            # 智谱 GLM
MOONSHOT_API_KEY=sk-xxxxxxxxxxxx    # 月之暗面 Kimi
BAICHUAN_API_KEY=sk-xxxxxxxxxxxx    # 百川智能
YI_API_KEY=xxxxxxxxxxxx             # 零一万物
ERNIE_API_KEY=xxxxxxxxxxxx          # 百度文心
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxx # 硅基流动
SPARK_API_KEY=xxxxxxxxxxxx          # 讯飞星火

# 通用密钥（当厂商特定密钥未设置时使用）
LLM_API_KEY=

# ======================================================================
# 自定义端点与模型（可选，默认使用各厂商标准配置）
# ======================================================================

# 自定义 API 地址（例如使用代理或私有部署）
# CLAUDE_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 自定义模型名（不填则使用各厂商默认模型）
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
# DEEPSEEK_MODEL=deepseek-chat

# ======================================================================
# 运行时参数
# ======================================================================

# LLM 推理参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# 缓存配置
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379

# FastAPI 服务配置
HOST=0.0.0.0
PORT=8000