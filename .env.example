# ======================================================================
# 语义级论文查重系统 — 环境变量配置
# ======================================================================

# ======================================================================
# LLM 厂商配置
# ======================================================================

# 选择 LLM 接口类型
#   claude  = Anthropic Claude（原生 SDK，支持 token 概率检测）
#   openai  = OpenAI 兼容接口（可对接任意兼容的 API 服务）
#   任意名称 = 同上，当作 OpenAI 兼容接口处理
LLM_PROVIDER=claude

# ======================================================================
# API 密钥
# ======================================================================

# Claude API (Anthropic)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxx

# OpenAI 兼容接口的 API 密钥
# （当 LLM_PROVIDER 为 "openai" 或自定义名称时使用）
LLM_API_KEY=

# ======================================================================
# 自定义端点与模型（自由配置）
# ======================================================================

# 自定义 API 地址 —— 可对接任意 OpenAI 兼容的 API
# 例如对接 DeepSeek、通义千问等：
# LLM_BASE_URL=https://api.deepseek.com
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 自定义模型名
# LLM_MODEL=deepseek-chat
# LLM_MODEL=qwen-plus

# Claude 专用配置（使用 CLAUDE_ 前缀覆盖通用配置）
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI 专用配置（当 LLM_PROVIDER=openai 时的默认值）
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ======================================================================
# 运行时参数
# ======================================================================

# LLM 推理参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# 缓存配置
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379

# FastAPI 服务配置
HOST=0.0.0.0
PORT=8000